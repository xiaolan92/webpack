{
  "presets": [
    ["@babel/preset-env", {
      "modules": false,
      "useBuiltIns": "entry",
      "corejs": "3",
      "targets": {
        "chrome": "58",
        "ie": "11"
      }
    }]
  ],
  "plugins": [
    "@vue/babel-plugin-jsx", 
    "@babel/plugin-transform-runtime",
    "@babel/plugin-syntax-dynamic-import",
    "@babel/plugin-proposal-unicode-property-regex"
     ]
}
